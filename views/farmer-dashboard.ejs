<%- include('partials/header') %>

<main class="dashboard">
    <h2>דשבורד חקלאי 🚜</h2>

    <div class="dashboard-grid">
        <!-- פרופיל -->
        <section class="card">
            <h3>הפרופיל שלי</h3>
            <div id="profileInfo"><p class="loading">טוען...</p></div>
            <button class="btn btn-secondary" onclick="toggleEditProfile()">ערוך פרופיל</button>
            <form id="editProfileForm" class="hidden" style="margin-top:12px">
                <div class="form-group"><label>שם מלא</label><input type="text" id="name" placeholder="שם מלא"></div>
                <div class="form-group"><label>טלפון</label><input type="tel" id="phone" placeholder="0501234567"></div>
                <div class="form-group"><label>מיקום החווה</label><input type="text" id="location" placeholder="עיר / אזור"></div>
                <div class="form-group"><label>דונמים</label><input type="number" id="dunams" placeholder="0" min="0"></div>
                <div class="form-group"><label>סוג גידול</label><input type="text" id="crop_type" placeholder="עגבניות, ענבים..."></div>
                <button type="submit" class="btn btn-primary btn-full">שמור שינויים</button>
            </form>
        </section>

        <!-- פרסום התנדבות חדשה -->
        <section class="card">
            <h3>פרסם התנדבות חדשה 📋</h3>
            <div id="taskMsg" class="msg hidden"></div>
            <form id="newTaskForm">
                <div class="form-group">
                    <label>כותרת</label>
                    <input type="text" id="title" required placeholder="למשל: קציר חיטה">
                </div>
                <div class="form-group">
                    <label>פירוט</label>
                    <textarea id="description" rows="2" placeholder="פרטים נוספים על העבודה..."></textarea>
                </div>
                <div class="form-group">
                    <label>סוג עבודה</label>
                    <select id="work_type" required>
                        <option value="">בחר...</option>
                        <option value="קציר">קציר</option>
                        <option value="שתילה">שתילה</option>
                        <option value="השקיה">השקיה</option>
                        <option value="ניכוש">ניכוש</option>
                        <option value="קטיף">קטיף</option>
                        <option value="אחר">אחר</option>
                    </select>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>מספר מתנדבים דרוש</label>
                        <input type="number" id="volunteers_needed" value="1" min="1">
                    </div>
                    <div class="form-group">
                        <label>שעות עבודה</label>
                        <input type="text" id="work_hours" placeholder="למשל: 08:00-13:00">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>תאריך התחלה</label>
                        <input type="date" id="start_date" required>
                    </div>
                    <div class="form-group">
                        <label>תאריך סיום</label>
                        <input type="date" id="end_date" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-full">פרסם התנדבות</button>
            </form>
        </section>

        <!-- ההתנדבויות שלי -->
        <section class="card full-width">
            <h3>ההתנדבויות שפרסמתי</h3>
            <div id="myTasks"><p class="loading">טוען...</p></div>
        </section>
    </div>
</main>

<script src="/js/farmer-dashboard.js"></script>
<%- include('partials/footer') %>
